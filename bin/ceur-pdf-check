#!/usr/bin/env bash
set -uo pipefail

usage() {
  cat <<'EOF'
Usage:
  ceur-pdf-check INPUT [--output REPORT.md] [--tests TESTS] [--reference-json-output REFERENCES.json]

INPUT may be a single PDF, DOCX, DOC, or ODT manuscript file or a directory containing supported manuscript files.

Options:
  -o, --output REPORT.md  Markdown report path. Defaults to ./ceur-pdf-check-report.md.
  -t, --tests TESTS       CEUR test set to run. Defaults to all.
  --reference-json-output REFERENCES.json
                           Write structured reference extraction data for API repair features.
  -h, --help              Show this help.

Examples:
  ceur-pdf-check paper.pdf --output report.md
  ceur-pdf-check paper.docx --output report.md
  ceur-pdf-check /work/papers --tests "readable copyright genai"
EOF
}

error() {
  echo "ceur-pdf-check: $*" >&2
}

is_pdf_file() {
  local source_path="$1"
  [[ "${source_path,,}" == *.pdf ]]
}

is_convertible_file() {
  local source_path="$1"
  case "${source_path,,}" in
    *.docx|*.doc|*.odt) return 0 ;;
    *) return 1 ;;
  esac
}

is_supported_manuscript() {
  local source_path="$1"
  is_pdf_file "$source_path" || is_convertible_file "$source_path"
}

copy_to_workdir() {
  local source_path="$1"
  local target_name="$2"

  cp "$source_path" "$WORKDIR/$target_name" || {
    error "cannot copy input file: $source_path"
    exit 2
  }
}

unique_pdf_name() {
  local candidate="$1"
  local stem="${candidate%.pdf}"
  local counter=2

  if [[ ! -e "$WORKDIR/$candidate" ]]; then
    echo "$candidate"
    return
  fi

  while [[ -e "$WORKDIR/${stem}_${counter}.pdf" ]]; do
    counter=$((counter + 1))
  done

  echo "${stem}_${counter}.pdf"
}

record_input_file() {
  local source_path="$1"
  local source_name
  source_name="$(basename "$source_path")"

  printf '%s\n' "$source_name" >> "$MANUSCRIPT_LIST"
}

copy_pdf_input() {
  local source_path="$1"
  local source_name
  local target_name
  source_name="$(basename "$source_path")"
  target_name="$(unique_pdf_name "$source_name")"

  copy_to_workdir "$source_path" "$target_name"
  record_input_file "$source_path"
}

convert_document_input() {
  local source_path="$1"
  local source_name
  local source_stem
  local conversion_dir
  local expected_pdf
  local target_name
  local convert_log="$CONVERSION_ROOT/libreoffice-conversion.log"

  if ! command -v libreoffice >/dev/null 2>&1; then
    error "libreoffice is not available on PATH for manuscript conversion"
    exit 2
  fi

  source_name="$(basename "$source_path")"
  source_stem="${source_name%.*}"
  conversion_dir="$(mktemp -d "$CONVERSION_ROOT/convert.XXXXXX")" || {
    error "cannot create conversion directory"
    exit 2
  }
  expected_pdf="$conversion_dir/$source_stem.pdf"

  if ! libreoffice --headless "-env:UserInstallation=file://$CONVERSION_ROOT/libreoffice-profile" --convert-to pdf --outdir "$conversion_dir" "$source_path" >> "$convert_log" 2>&1; then
    error "cannot convert manuscript to PDF: $source_path"
    if [[ -s "$convert_log" ]]; then
      tail -n 20 "$convert_log" >&2 || true
    fi
    exit 2
  fi

  if [[ ! -s "$expected_pdf" ]]; then
    error "manuscript conversion did not produce a PDF: $source_path"
    if [[ -s "$convert_log" ]]; then
      tail -n 20 "$convert_log" >&2 || true
    fi
    exit 2
  fi

  target_name="$(unique_pdf_name "$(basename "$expected_pdf")")"
  copy_to_workdir "$expected_pdf" "$target_name"
  record_input_file "$source_path"
}

process_input_file() {
  local source_path="$1"

  if is_pdf_file "$source_path"; then
    copy_pdf_input "$source_path"
  elif is_convertible_file "$source_path"; then
    convert_document_input "$source_path"
  else
    error "unsupported manuscript format: $source_path"
    exit 2
  fi
}

INPUT=""
OUTPUT=""
TESTS="all"
REFERENCE_JSON_OUTPUT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -o|--output)
      if [[ $# -lt 2 || "$2" == -* ]]; then
        error "--output requires a report path"
        exit 2
      fi
      OUTPUT="$2"
      shift 2
      ;;
    -t|--tests)
      if [[ $# -lt 2 || "$2" == -* ]]; then
        error "--tests requires a test list"
        exit 2
      fi
      TESTS="$2"
      shift 2
      ;;
    --reference-json-output)
      if [[ $# -lt 2 || "$2" == -* ]]; then
        error "--reference-json-output requires a JSON path"
        exit 2
      fi
      REFERENCE_JSON_OUTPUT="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      error "unknown option: $1"
      usage >&2
      exit 2
      ;;
    *)
      if [[ -n "$INPUT" ]]; then
        error "only one input path is supported"
        usage >&2
        exit 2
      fi
      INPUT="$1"
      shift
      ;;
  esac
done

if [[ $# -gt 0 ]]; then
  if [[ -n "$INPUT" ]]; then
    error "only one input path is supported"
    usage >&2
    exit 2
  fi
  INPUT="$1"
fi

if [[ -z "$INPUT" ]]; then
  error "missing manuscript file or directory"
  usage >&2
  exit 2
fi

if [[ -z "$OUTPUT" ]]; then
  OUTPUT="$PWD/ceur-pdf-check-report.md"
elif [[ "$OUTPUT" != /* ]]; then
  OUTPUT="$PWD/$OUTPUT"
fi

if [[ -n "$REFERENCE_JSON_OUTPUT" && "$REFERENCE_JSON_OUTPUT" != /* ]]; then
  REFERENCE_JSON_OUTPUT="$PWD/$REFERENCE_JSON_OUTPUT"
fi

if [[ -d "$OUTPUT" ]]; then
  error "output path must be a file, not a directory: $OUTPUT"
  exit 2
fi

if [[ ! -e "$INPUT" ]]; then
  error "input path does not exist: $INPUT"
  exit 2
fi

INPUT_PATH="$(realpath "$INPUT")" || {
  error "cannot resolve input path: $INPUT"
  exit 2
}

OUTPUT_DIR="$(dirname "$OUTPUT")"
mkdir -p "$OUTPUT_DIR" || {
  error "cannot create report directory: $OUTPUT_DIR"
  exit 2
}

if [[ -n "$REFERENCE_JSON_OUTPUT" ]]; then
  REFERENCE_JSON_DIR="$(dirname "$REFERENCE_JSON_OUTPUT")"
  mkdir -p "$REFERENCE_JSON_DIR" || {
    error "cannot create reference JSON directory: $REFERENCE_JSON_DIR"
    exit 2
  }
fi

if ! command -v check-pdf-errors >/dev/null 2>&1; then
  error "check-pdf-errors is not available on PATH"
  exit 2
fi

WORKDIR="$(mktemp -d)" || {
  error "cannot create temporary work directory"
  exit 2
}
CONVERSION_ROOT="$(mktemp -d)" || {
  rm -rf "$WORKDIR"
  error "cannot create temporary conversion directory"
  exit 2
}
RAW_LOG="$WORKDIR/check-pdf-errors.raw.log"
CLEAN_LOG="$WORKDIR/check-pdf-errors.clean.log"
FINDINGS="$WORKDIR/findings.log"
REFERENCE_REPORT="$WORKDIR/reference-check.md"
REFERENCE_JSON="$WORKDIR/reference-check.json"
REFERENCE_ERRORS="$WORKDIR/reference-errors.log"
INPUT_LIST="$WORKDIR/input-files.log"
MANUSCRIPT_LIST="$WORKDIR/input-manuscripts.log"
trap 'rm -rf "$WORKDIR" "$CONVERSION_ROOT"' EXIT
: > "$MANUSCRIPT_LIST"

if [[ -f "$INPUT_PATH" ]]; then
  if ! is_supported_manuscript "$INPUT_PATH"; then
    error "single-file input must be a PDF, DOCX, DOC, or ODT manuscript: $INPUT_PATH"
    exit 2
  fi
  process_input_file "$INPUT_PATH"
elif [[ -d "$INPUT_PATH" ]]; then
  while IFS= read -r -d '' manuscript; do
    process_input_file "$manuscript"
  done < <(find "$INPUT_PATH" -maxdepth 1 -type f \( -iname '*.pdf' -o -iname '*.docx' -o -iname '*.doc' -o -iname '*.odt' \) -print0 | sort -z)
  for companion in index.html watermark-log.txt; do
    if [[ -f "$INPUT_PATH/$companion" ]]; then
      copy_to_workdir "$INPUT_PATH/$companion" "$companion"
    fi
  done
else
  error "input must be a supported manuscript file or directory: $INPUT_PATH"
  exit 2
fi

MANUSCRIPT_COUNT="$(wc -l < "$MANUSCRIPT_LIST" | tr -d ' ')"
if [[ "$MANUSCRIPT_COUNT" -eq 0 ]]; then
  error "no supported manuscript files found in input: $INPUT_PATH"
  exit 2
fi

find "$WORKDIR" -maxdepth 1 -type f -iname '*.pdf' -printf '%f\n' | sort > "$INPUT_LIST"
PDF_COUNT="$(wc -l < "$INPUT_LIST" | tr -d ' ')"
if [[ "$PDF_COUNT" -eq 0 ]]; then
  error "no PDFs were available for checking after manuscript conversion: $INPUT_PATH"
  exit 2
fi

(
  cd "$WORKDIR" || exit 1
  check-pdf-errors "$TESTS"
) >"$RAW_LOG" 2>&1
CHECK_EXIT=$?

perl -pe 's/\r/\n/g' "$RAW_LOG" > "$CLEAN_LOG"
FINDING_PATTERN='^(PDF file |Error: |ERROR | ==========>| ===>| --> |WARNING:|Can.t open |No file with filetype|Unexpected error)'
grep -E "$FINDING_PATTERN" "$CLEAN_LOG" > "$FINDINGS" || true

FINDING_COUNT="$(wc -l < "$FINDINGS" | tr -d ' ')"
mapfile -t PDF_FILES < "$INPUT_LIST"
(
  cd "$WORKDIR" || exit 1
  ceur-reference-check --json-output "$REFERENCE_JSON" -- "${PDF_FILES[@]}"
) > "$REFERENCE_REPORT" 2>&1
REFERENCE_EXIT=$?
grep -E '^- ERROR:' "$REFERENCE_REPORT" > "$REFERENCE_ERRORS" || true
REFERENCE_ERROR_COUNT="$(wc -l < "$REFERENCE_ERRORS" | tr -d ' ')"
if [[ "$REFERENCE_EXIT" -ne 0 && "$REFERENCE_ERROR_COUNT" -eq 0 ]]; then
  echo "- ERROR: Reference checker exited with code $REFERENCE_EXIT without a structured error." >> "$REFERENCE_REPORT"
  REFERENCE_ERROR_COUNT=1
fi
REFERENCE_STATUS="pass"
if [[ "$REFERENCE_ERROR_COUNT" -gt 0 ]]; then
  REFERENCE_STATUS="fail"
fi

if [[ -n "$REFERENCE_JSON_OUTPUT" && -s "$REFERENCE_JSON" ]]; then
  cp "$REFERENCE_JSON" "$REFERENCE_JSON_OUTPUT" || {
    error "cannot write reference JSON output: $REFERENCE_JSON_OUTPUT"
    exit 2
  }
fi

STATUS="pass"
if [[ "$CHECK_EXIT" -ne 0 || "$FINDING_COUNT" -gt 0 || "$REFERENCE_STATUS" != "pass" ]]; then
  STATUS="fail"
fi

if ! {
  echo "# CEUR PDF Check Report"
  echo
  echo "| Field | Value |"
  echo "| --- | --- |"
  echo "| Status | $STATUS |"
  echo "| Generated | $(date -u '+%Y-%m-%dT%H:%M:%SZ') |"
  echo "| Input | $INPUT_PATH |"
  echo "| Manuscript count | $MANUSCRIPT_COUNT |"
  echo "| PDF count | $PDF_COUNT |"
  echo "| Tests | $TESTS |"
  echo "| Checker exit code | $CHECK_EXIT |"
  echo "| Finding lines | $FINDING_COUNT |"
  echo "| Reference status | $REFERENCE_STATUS |"
  echo "| Reference errors | $REFERENCE_ERROR_COUNT |"
  echo
  echo "## Input Manuscripts"
  echo
  while IFS= read -r manuscript_name; do
    echo "- $manuscript_name"
  done < "$MANUSCRIPT_LIST"
  echo
  echo "## Checked PDFs"
  echo
  while IFS= read -r pdf_name; do
    echo "- $pdf_name"
  done < "$INPUT_LIST"
  echo
  echo "## Reference Check"
  echo
  cat "$REFERENCE_REPORT"
  echo
  echo "## Findings"
  echo
  if [[ "$FINDING_COUNT" -eq 0 ]]; then
    echo "No likely findings were detected in the CEUR checker output."
  else
    while IFS= read -r line; do
      echo "- $line"
    done < "$FINDINGS"
  fi
  echo
  echo "## Raw CEUR Output"
  echo
  echo '```text'
  cat "$CLEAN_LOG"
  echo '```'
} > "$OUTPUT"; then
  error "cannot write report: $OUTPUT"
  exit 2
fi

echo "Report written to $OUTPUT"
echo "Status: $STATUS"

if [[ "$STATUS" != "pass" ]]; then
  exit 1
fi

exit 0
